> def _detect_conflicts(
>     existing_tags: list[str],
>     existing_priority: str,
>     existing_template_name: str | None,
>     incoming: Template,
> ) -> list[dict[str, object]]:
>     """Return a list of conflict dicts between existing state and the incoming template.
  
>     Checks:
>     - tags: both sides non-empty and different
>     - priority: existing is non-default and incoming differs
>     - workflow.steps: existing template set and steps differ
>     - hooks: existing template set and hook keys overlap
>     """
>     conflicts: list[dict[str, object]] = []
  
      # Tags conflict
>     if existing_tags and incoming.tags and set(existing_tags) != set(incoming.tags):
>         conflicts.append(
>             {
>                 "field": "tags",
>                 "existing": existing_tags,
>                 "incoming": incoming.tags,
>                 "resolution": "merge or replace?",
>             }
>         )
  
      # Priority conflict
>     if (
>         existing_priority != "medium"
>         and incoming.priority is not None
>         and existing_priority != incoming.priority
>     ):
>         conflicts.append(
>             {
>                 "field": "priority",
>                 "existing": existing_priority,
>                 "incoming": incoming.priority,
>                 "resolution": "which wins?",
>             }
>         )
  
      # Workflow + hooks conflicts (only when a previous template was applied)
>     if existing_template_name is not None:
>         prev_template = storage.load_template(existing_template_name)
>         if prev_template is not None:
              # Workflow steps conflict
>             if prev_template.workflow.steps != incoming.workflow.steps:
>                 conflicts.append(
>                     {
>                         "field": "workflow.steps",
>                         "existing": prev_template.workflow.steps,
>                         "incoming": incoming.workflow.steps,
>                         "resolution": "merge or override?",
>                     }
>                 )
              # Hooks conflict (overlapping hook event keys)
>             overlapping_hooks = set(prev_template.hooks) & set(incoming.hooks)
>             if overlapping_hooks:
>                 conflicts.append(
>                     {
>                         "field": "hooks",
>                         "existing": prev_template.hooks,
>                         "incoming": incoming.hooks,
>                         "resolution": "additive or override?",
>                     }
>                 )
  
>     return conflicts
  
  
