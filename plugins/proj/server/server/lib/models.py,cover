> @dataclass
> class Template:
>     name: str
>     type: str  # "project" | "task"
>     description: str = ""
>     tags: list[str] = field(default_factory=list)
>     priority: str | None = None
>     workflow: WorkflowConfig = field(default_factory=WorkflowConfig)
>     hooks: dict[str, list[str]] = field(default_factory=dict)
>     claudemd_snippet: str = ""
>     bundled_task_templates: list[str] = field(default_factory=list)
  
>     def to_dict(self) -> dict[str, object]:
>         return {
>             "name": self.name,
>             "type": self.type,
>             "description": self.description,
>             "tags": self.tags,
>             "priority": self.priority,
>             "workflow": self.workflow.to_dict(),
>             "hooks": self.hooks,
>             "claudemd_snippet": self.claudemd_snippet,
>             "bundled_task_templates": self.bundled_task_templates,
>         }
  
>     @classmethod
>     def from_dict(cls, data: dict[str, object]) -> Template:
>         tags_raw = data.get("tags", [])
>         hooks_raw = data.get("hooks", {})
>         bundled_raw = data.get("bundled_task_templates", [])
>         workflow_raw = data.get("workflow", {})
>         priority = data.get("priority")
>         return cls(
>             name=str(data["name"]),
>             type=str(data["type"]),
>             description=str(data.get("description", "")),
>             tags=list(tags_raw) if isinstance(tags_raw, list) else [],
>             priority=str(priority) if isinstance(priority, str) else None,
>             workflow=WorkflowConfig.from_dict(workflow_raw if isinstance(workflow_raw, dict) else {}),  # type: ignore[arg-type]
>             hooks=dict(hooks_raw) if isinstance(hooks_raw, dict) else {},  # type: ignore[arg-type]
>             claudemd_snippet=str(data.get("claudemd_snippet", "")),
>             bundled_task_templates=list(bundled_raw) if isinstance(bundled_raw, list) else [],
>         )
  
  
